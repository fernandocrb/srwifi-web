How it works START -->
<section class="pb-0 overflow-hidden" id="servicios">
	<div class="container">
		<!-- Title -->
		<div class="inner-container-small text-center mb-4 mb-sm-6">
			<span class="text-primary fw-bold text-uppercase">Portal Cautivo</span>
			<h2 class="mb-0 mt-3">El impacto de Wi-fi gratis para tu negocio</h2>
		</div>

		<!-- Steps START -->
		<div class="row">
			<div class="col-xl-10 mx-auto">
				<!-- Step 1 -->
				<div class="row flex-lg-nowrap align-items-center position-relative mb-8">
					<!-- SVG decoration -->
					<figure class="position-absolute top-100 start-50 mt-n3">
						<svg width="108.7px" height="116.7px" viewBox="0 0 108.7 116.7"
							style="enable-background:new 0 0 108.7 116.7;" xml:space="preserve">
							<path class="fill-mode opacity-5"
