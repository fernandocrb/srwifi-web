<!-- =======================
Main hero START -->
<section id="contactar" class="pt-xl-8">
	<div class="container">
		<div class="row g-4 g-xxl-5">
			<div class="col-xl-9 mx-auto">
				<!-- Image -->
				<img src="assets/images/bg/02.jpg" class="rounded" alt="contact-bg">

				<!-- Contact form START -->
				<div class="row mt-n5 mt-sm-n7 mt-md-n8">
					<div class="col-11 col-lg-9 mx-auto">
						<div class="card shadow p-4 p-sm-5 p-md-6">
							<!-- Card header -->
							<div class="card-header border-bottom px-0 pt-0 pb-5">
								<!-- Breadcrumb -->
								<nav class="mb-3" aria-label="breadcrumb">
									<ol class="breadcrumb breadcrumb-dots pt-0">
										<li class="breadcrumb-item"><a href="index.html">Inicio</a></li>
										<li class="breadcrumb-item active" aria-current="page">Contactar Ahora</li>
									</ol>
								</nav>
								<!-- Title -->
								<h1 class="mb-3 h3">Vamos a subir de nivel a tu marca, juntos</h1>
								<p class="mb-0">Puedes contactarnos cuandos quieras a: <a
										href="#">ventas@elsrwifi.com</a></p>
							</div>
							<!-- Card body & form -->
							<form autocomplete="false" role="form" method="post"
								action="https://formularios.educapanama.net/form/submit?formId=11"
								id="mauticform_elsrwificontacto" data-mautic-form="elsrwificontacto"
								enctype="multipart/form-data" class="card-body px-0 pb-0 pt-5">
								<!-- Name -->
								<div class="input-floating-label form-floating mb-4">
									<input type="text" class="form-control bg-transparent"
										id="mauticform_input_elsrwificontacto_nombre" name="mauticform[nombre]"
										placeholder="Nombre">
									<label for="mauticform_input_elsrwificontacto_nombre">Nombre</label>
								</div>
								<!-- Email -->
								<div class="input-floating-label form-floating mb-4">
									<input type="email" class="form-control bg-transparent"
										id="mauticform_input_elsrwificontacto_correo_de_empresa"
										name="mauticform[correo_de_empresa]" placeholder="name@example.com">
									<label for="mauticform_input_elsrwificontacto_correo_de_empresa">Correo
										Empresarial</label>
								</div>
								<!-- Number -->
								<div class="input-floating-label form-floating mb-4">
									<input type="text" class="form-control bg-transparent"
										id="mauticform_input_elsrwificontacto_nombre_de_la_organizacion"
										name="mauticform[nombre_de_la_organizacion]"
										placeholder="Nombre de la Organización">
									<label for="mauticform_input_elsrwificontacto_nombre_de_la_organizacion">Nombre de
										la Organización</label>
								</div>
								<!-- Message -->
								<div class="input-floating-label form-floating mb-4">
									<textarea class="form-control bg-transparent"
										placeholder="¿En que podemos ayudarte?"
										id="mauticform_input_elsrwificontacto_mensaje" name="mauticform[mensaje]"
										style="height: 100px"></textarea>
									<label for="mauticform_input_elsrwificontacto_mensaje">Mensaje</label>
								</div>
								<!-- Button -->
								<button type="submit" name="mauticform[submit]"
									id="mauticform_input_elsrwificontacto_submit" value=""
									class="btn btn-lg btn-primary mb-0">Enviar Mensaje</button>
								<input type="hidden" name="mauticform[formId]" id="mauticform_elsrwificontacto_id"
									value="11">
								<input type="hidden" name="mauticform[return]" id="mauticform_elsrwificontacto_return"
									value="">
								<input type="hidden" name="mauticform[formName]" id="mauticform_elsrwificontacto_name"
									value="elsrwificontacto">
							</form>
						</div>
					</div>
				</div>
				<!-- Contact form END -->
			</div>
		</div> <!-- Row END -->
	</div>
</section>
<!-- =======================
Contact info & Map START -->
<Section style="margin-bottom: 50px;" class="py-0">
	<div class="container">
		<div class="row row-cols-1 row-cols-lg-2 g-4">
			<!-- Address info -->


			<!-- Email info -->
			<div class="col">
				<div class="card card-body bg-light border p-sm-5">
					<!-- Icon -->
					<div class="mb-4"><i class="bi bi-envelope fa-xl text-primary"></i></div>
					<!-- Title -->
					<h6 class="mb-3">Envíanos un Email</h6>
					<p>Estamos al tanto de todo y nuestro objetivo es responder a todas las consultas dentro de las 24
						horas.</p>
					<a href="mailto:ventas@elsrwifi.com"
						class="heading-color text-primary-hover text-decoration-underline mb-0">ventas@elsrwifi.com</a>
				</div>
			</div>

			<!-- Contact info -->
			<div class="col">
				<div class="card card-body bg-light border p-sm-5">
					<!-- Icon -->
