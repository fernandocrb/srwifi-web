Main Banner START -->
<section class="pt-0">
	<!-- Slider START -->
	<div class="swiper overflow-hidden" data-swiper-options='{
		"effect": "fade",
		"speed":"1000",
		"autoplay":{
			"delay": 3000, 
			"disableOnInteraction": false
		},
		"pagination":{
			"el":".swiper-pagination",
			"clickable":"true"
		}}'>

		<div class="swiper-wrapper">
			<!-- Slider item -->
			<div class="swiper-slide">
				<div class="card overflow-hidden min-vh-100 rounded-0"
					style="background:url(image.png) no-repeat; background-size:cover; background-position:center;">
					<!-- Bg overlay -->
					<div class="bg-overlay bg-linear-overlay"></div>

					<!-- Card image overlay -->
					<div class="position-relative z-index-2 d-flex flex-column m-auto h-100 py-9">
						<div class="container">
							<div class="row">
								<div class="col-sm-11 col-lg-8 col-xl-7 text-center m-auto">
									<span class="bg-white bg-opacity-10 text-white small rounded-3 px-3 py-2">🛜
										Somos los Expertos en Wi-fi</span>
									<!-- Title -->
									<h1 class="text-white display-4 my-4">Wifi para <span
											class="text-primary">Hoteles</span> </h1>
									<p class="text-white mb-5"> Ofrece mejor experiencia a tus huéspedes proveeyendo internet gratis y mejore como sus clientes perciben su marca</p>
									<a class="btn btn-lg btn-white icon-link icon-link-hover mb-0" href="#contactar">Contactar<i
											class="bi bi-arrow-right"></i> </a>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>

			<!-- Slider item -->
			<div class="swiper-slide">
				<div class="card overflow-hidden min-vh-100 rounded-0"
					style="background:url(https://www.socialwibox.es/wp-content/uploads/2022/05/wifi-restaurantes-conectado-disfrutas-tu-comida-632.png) no-repeat; background-size:cover; background-position:center;">
					<!-- Bg overlay -->
					<div class="bg-overlay bg-linear-overlay"></div>

					<!-- Content -->
					<div class="position-relative z-index-2 d-flex flex-column m-auto h-100 py-9">
						<div class="container">
							<div class="row">
								<div class="col-sm-11 col-lg-8 mt-auto">
									<!-- Title -->
									<h1 class="text-white display-4 mb-4">Wifi para <span class="fw-light">Restaurantes</span><span
											class="fw-light"></span></h1>
									<p class="text-white mb-5">Haz el menú de tu restaurante mas agradable, agregando wifi a tu sucursal. </p>
									<a class="btn btn-lg btn-primary icon-link icon-link-hover mb-0" href="#servicios">Explora
